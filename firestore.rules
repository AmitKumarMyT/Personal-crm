rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Entity Validation Blueprints
    
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'goal']) &&
             data.userId == request.auth.uid &&
             data.goal == 'hypertrophy' &&
             data.userId is string &&
             (data.name == null || data.name is string) &&
             (data.stats == null || data.stats is map);
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['userId', 'session', 'exercises', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.session is map &&
             data.exercises is list &&
             data.exercises.size() <= 20;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'text', 'role', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 2000 &&
             data.role in ['user', 'model'];
    }

    function isValidContact(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['userId', 'amount', 'payer', 'involved', 'personId', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.payer is string &&
             data.involved is list &&
             data.personId is string;
    }

    function isValidExpenseChat(data) {
      return data.keys().hasAll(['userId', 'text', 'role', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 2000 &&
             data.role in ['user', 'ai'];
    }

    // 3. Collection Match Blocks
    
    match /users/{userId} {
      // Path Variable Hardening
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      match /workouts/{workoutId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        
        allow create: if isOwner(userId) && isValidWorkout(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isOwner(userId) && isValidWorkout(incoming()) && incoming().userId == request.auth.uid && incoming().userId == existing().userId;
      }

      match /chats/{chatId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        
        allow create: if isOwner(userId) && isValidChat(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isOwner(userId) && isValidChat(incoming()) && incoming().userId == request.auth.uid && incoming().userId == existing().userId;
      }

      match /contacts/{contactId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        
        allow create: if isOwner(userId) && isValidContact(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isOwner(userId) && isValidContact(incoming()) && incoming().userId == request.auth.uid && incoming().userId == existing().userId;
        allow delete: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        
        allow create: if isOwner(userId) && isValidExpense(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isOwner(userId) && isValidExpense(incoming()) && incoming().userId == request.auth.uid && incoming().userId == existing().userId;
        allow delete: if isOwner(userId);
      }

      match /expense_chats/{chatId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        
        allow create: if isOwner(userId) && isValidExpenseChat(incoming()) && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }
    }
  }
}
